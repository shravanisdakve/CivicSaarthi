# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash # Or other Gemini model, e.g., gemini-1.5-pro

# Frontend (Vite) specific Gemini API Key (if different or used directly in frontend)
VITE_GEMINI_API_KEY=your_vite_gemini_api_key_here

# Google Maps Platform Configuration
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Configuration
# Get these from your Firebase project settings -> Project settings -> General -> Your apps -> Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here

# Google Analytics Configuration
VITE_GOOGLE_ANALYTICS_ID=your_google_analytics_measurement_id_here

# Google Cloud Authentication (for backend services like Natural Language API)
# This should point to your service account key file for backend authentication.
# DO NOT COMMIT THIS FILE. In production, use environment variables or secret manager directly.
GOOGLE_APPLICATION_CREDENTIALS=./path/to/your/service-account-key.json

# Google Calendar API Configuration (for backend OAuth flow)
# Get these from your Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs
CALENDAR_CLIENT_ID=your_calendar_client_id_here
CALENDAR_CLIENT_SECRET=your_calendar_client_secret_here
CALENDAR_REDIRECT_URI=http://localhost:8080/api/calendar/oauth2callback # Must match authorized redirect URI in Google Cloud Console

# Google Custom Search API Configuration (for Advanced RAG)
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_CSE_ID=your_google_custom_search_engine_id_here

